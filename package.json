{
  "name": "ejo100",
  "private": true,
  "version": "1.0.0",
  "description": "EJO 100 Enterprise Platform - reusable Enterprise Operating System (EnterpriseOS)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:website": "npm run dev --workspace=apps/website",
    "dev:portal": "npm run dev --workspace=apps/portal",
    "dev:api": "npm run start:dev --workspace=apps/api",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
