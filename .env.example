# ---------------------------------------------------------------------------
# EJO 100 Enterprise Platform - Environment Variables (example)
# Copy to .env and fill in real values. Never commit the real .env file.
# ---------------------------------------------------------------------------

# Database (Neon — DATABASE_URL is the pooled connection used at runtime,
# DIRECT_URL is the unpooled connection Prisma needs for migrations)
DATABASE_URL="postgresql://user:password@ep-example-pooler.neon.tech/ejo100?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-example.neon.tech/ejo100?sslmode=require"

# Auth (Better Auth)
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
BETTER_AUTH_URL="http://localhost:3001"

# Redis
REDIS_URL="redis://localhost:6379"

# Storage - Supabase (initial provider)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-me"
SUPABASE_STORAGE_BUCKET="ejo100"

# Storage - Cloudflare R2 (future provider)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""

# Email (Nodemailer)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="EJO 100 Platform <no-reply@example.com>"

# App URLs
NEXT_PUBLIC_WEBSITE_URL="http://localhost:3000"
NEXT_PUBLIC_PORTAL_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Active tenant (Phase One)
NEXT_PUBLIC_ACTIVE_COMPANY_SLUG="kewalram-nigeria"
